{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Read|Grep|Glob",
        "hooks": [
          { "type": "command", "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/trace-doc-access.mjs\"" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          { "type": "command", "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/trace-doc-access.mjs\" --subagent-stop" }
        ]
      }
    ]
  },
  "permissions": {
    "allow": ["mcp__db"],
    "deny": []
  }
}
