# ── MCP `db` (read-only) ─────────────────────────────────────────────────────────
# Supabase Session Pooler — "Session mode" URL (port 5432), mcp_readonly role.
# Used only by the `db` MCP (dba/docs-sync sub-agents); the app never reads this.
# postgresql://mcp_readonly.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=

# ── Runtime (app) ──────────────────────────────────────────────────────────────
# Supabase Session Pooler, table-owner role (postgres.[project-ref]) — the app
# connects as owner and bypasses RLS; per-user isolation lives in server actions
# (WHERE user_id = session.userId), not Postgres. Used by src/data/db.ts.
# postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL_APP=

# ── Migrations (drizzle-kit) ───────────────────────────────────────────────────
# Supabase Direct Connection — bypasses the pooler; required for DDL migrations
# Found in: Supabase → Project Settings → Database → Connection string → Direct
# postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# OR: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL_MIGRATE=

# Node environment
NODE_ENV=development

# ── Auth (Supabase) ─────────────────────────────────────────────────────────────
# Project Settings → API. The anon key is public (safe in the browser bundle);
# the service role key is a server-only secret (bypasses RLS + Admin API) used
# by auth-write to create users. Never prefix it with NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Base URL the email links (recovery, email change, verification) redirect
# back to (/auth/confirm). Must be registered in Supabase Auth → URL
# Configuration → Redirect URLs. Defaults to http://localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL=
